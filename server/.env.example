# Copie para server/.env (nunca commite .env — já está no .gitignore).
# Projeto: rafael-portfolio | ref: gbuxgznmvchkhnwhcwvk
#
# ⚠️ Segurança: se você colou chaves em algum lugar público, regenere no painel:
# Supabase → Settings → API → "Rotate" / nova service_role e anon.

# --- Storage (bucket "imagem", público) ---
SUPABASE_URL=https://gbuxgznmvchkhnwhcwvk.supabase.co
SUPABASE_STORAGE_BUCKET=imagem
SUPABASE_STORAGE_PUBLIC=true
# Se o bucket for privado, use false e preencha a service role (não use anon no servidor):
# SUPABASE_STORAGE_PUBLIC=false
# SUPABASE_SERVICE_ROLE_KEY=cole_aqui_service_role_jwt

# Se os arquivos estiverem numa subpasta dentro do bucket:
# SUPABASE_STORAGE_KEY_PREFIX=pasta_opcional

# --- API local ---
PORT=8080
CORS_ORIGIN=http://localhost:8086
FRONTEND_URL=http://localhost:8086

# Blog (news) = dev.to via backend (não usa este Postgres).

# --- Postgres (Supabase) — contatos / usuários (Drizzle) ---
# Host direto do projeto gbuxgznmvchkhnwhcwvk. Use senha forte; troque se vazou em algum lugar.
# A senha na URL precisa estar codificada se tiver @, #, etc. (encodeURIComponent).
DATABASE_URL=postgresql://postgres:Portifolio_Data_2026_Ref@db.gbuxgznmvchkhnwhcwvk.supabase.co:5432/postgres?sslmode=require
#
# Alternativa (pooler, bom para deploy serverless):
# DATABASE_URL=postgresql://postgres.gbuxgznmvchkhnwhcwvk:[POOLER_PASSWORD]@aws-0-[regiao].pooler.supabase.com:6543/postgres?sslmode=require
#
# Depois de definir DATABASE_URL, rode migrações (na pasta server):
#   npx drizzle-kit push
# ou o script que você usar para aplicar server/drizzle/*.sql

# Opcional: sessão / OAuth antigo do template
# JWT_SECRET=
# OAUTH_SERVER_URL=



# Legado Forge (só se não usar Supabase Storage)
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=
