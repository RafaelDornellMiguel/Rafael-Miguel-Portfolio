{
  "name": "portifolio",
  "version": "1.0.0",
  "description": "Portfólio reestruturado - Frontend & Backend",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,magenta \"cd client && npm run dev\" \"cd server && npm run dev\"",
    "dev:client": "npm run dev --prefix client",
    "dev:server": "npm run dev --prefix server",
    "build": "cd client && npm run build"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.1",
    "@trpc/server": "^10.45.2",
    "@vercel/node": "latest",
    "axios": "^1.7.9",
    "clsx": "^2.1.1",
    "cookie": "^1.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.31.2",
    "express": "^4.19.2",
    "jose": "^5.9.6",
    "lucide-react": "^1.14.0",
    "pg": "^8.13.1",
    "postgres": "^3.4.4",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "concurrently": "^9.1.2",
    "dotenv-cli": "^11.0.0",
    "supabase": "^2.98.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": "20.x"
  }
}
