{
  "name": "portifolio",
  "version": "1.0.0",
  "description": "Portfólio reestruturado - Frontend & Backend",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,magenta \"npm run dev --prefix client\" \"npm run dev --prefix server\"",
    "dev:client": "npm run dev --prefix client",
    "dev:server": "npm run dev --prefix server",
    "build": "cd client && pnpm run build"
  },
  "dependencies": {
     "@vercel/node": "latest",
    "@trpc/server": "^11.16.0",
    "superjson": "^1.13.3",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "cors": "^2.8.5",
    "pg": "^8.20.0",
    "drizzle-orm": "^0.44.7",
    "cookie": "^1.1.1",
    "jose": "^6.1.0",
    "axios": "^1.12.2",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "dotenv-cli": "^11.0.0",
    "typescript": "^5.9.3",
    "@types/express": "^4.17.21",
    "@types/pg": "^8.20.0"
  },
  "engines": {
    "node": "20.x"
  }
}